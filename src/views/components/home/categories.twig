{# ══════════════════════════════════════════════════════════════
   CATEGORIES — Dynamic from your Salla store categories
   ══════════════════════════════════════════════════════════════ #}

<section class="coffee-section" id="categories">
  <div class="coffee-section-inner">

    <div class="section-header">
      <div>
        <span class="section-label">Categories</span>
        <h2 class="section-title">{{ trans('pages.home.choose') }} <strong>{{ trans('pages.home.your_category') }}</strong></h2>
      </div>
    </div>

    <div class="categories-grid">
      {% for category in categories %}
        <a href="{{ category.url }}" class="category-card">
          {% if category.image.url %}
            <img src="{{ category.image.url }}" alt="{{ category.name }}" class="category-image" loading="lazy">
          {% endif %}
          <div class="category-name">{{ category.name }}</div>
          <div class="category-count">{{ category.products_count }} {{ trans('pages.home.product') }}</div>
        </a>
      {% else %}
        {# Fallback if no categories exist yet #}
        <div class="category-card">
          <div class="category-name">{{ trans('pages.home.no_categories') }}</div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>
