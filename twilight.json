{
  "name": "coffee-roastery-theme",
  "version": "1.0.0",
  "features": [
    "header",
    "footer",
    "product-card",
    "product-options",
    "comments",
    "loyalty"
  ],
  "components": [
    {
      "title": "هيرو فيديو",
      "title_en": "Hero Video",
      "icon": "sicon-play-circle",
      "file": "home.hero"
    },
    {
      "title": "الأقسام",
      "title_en": "Categories",
      "icon": "sicon-grid",
      "file": "home.categories"
    },
    {
      "title": "المنتجات",
      "title_en": "Products",
      "icon": "sicon-shopping-bag",
      "file": "home.products"
    },
    {
      "title": "مميزاتنا",
      "title_en": "Features",
      "icon": "sicon-star",
      "file": "home.features"
    },
    {
      "title": "أدوات التحضير",
      "title_en": "Tools",
      "icon": "sicon-coffee",
      "file": "home.tools"
    },
    {
      "title": "الاشتراك الشهري",
      "title_en": "Subscription",
      "icon": "sicon-refresh-cw",
      "file": "home.subscription"
    },
    {
      "title": "آراء العملاء",
      "title_en": "Testimonials",
      "icon": "sicon-message-circle",
      "file": "home.testimonials"
    },
    {
      "title": "النشرة البريدية",
      "title_en": "Newsletter",
      "icon": "sicon-mail",
      "file": "home.newsletter"
    },
    {
      "title": "شريط إعلانات",
      "title_en": "Announcement Bar",
      "icon": "sicon-megaphone",
      "file": "home.announcement-bar"
    },
    {
      "title": "شريط تمرير",
      "title_en": "Divider Band",
      "icon": "sicon-minus",
      "file": "home.divider-band"
    }
  ],
  "settings": [
    {
      "name": "hero_video_url",
      "type": "string",
      "label": "رابط فيديو الهيرو",
      "default": ""
    },
    {
      "name": "hero_title",
      "type": "string",
      "label": "عنوان الهيرو",
      "default": "تذوق نكهة القهوة الحقيقية"
    },
    {
      "name": "hero_subtitle",
      "type": "string",
      "label": "وصف الهيرو",
      "default": "حبوب مختارة بعناية من أفضل المزارع حول العالم"
    },
    {
      "name": "whatsapp_number",
      "type": "string",
      "label": "رقم الواتساب",
      "default": ""
    },
    {
      "name": "subscription_price",
      "type": "string",
      "label": "سعر الاشتراك الشهري",
      "default": "129"
    }
  ]
}
